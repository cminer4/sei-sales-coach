generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuid_ossp(map: "uuid-ossp", schema: "extensions"), vector]
}

model Coach {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String
  slug              String             @unique
  description       String?
  isActive          Boolean            @default(true) @map("is_active")
  features          Json               @default("{\"rating_method\": \"in-app\", \"email_delay_hours\": 24, \"enable_user_ratings\": true, \"enable_post_session_email\": false}")
  llmConfig         Json               @default("{\"model\": \"claude-sonnet-4-5-20250929\", \"agent_mode\": \"coach\", \"max_tokens\": 500, \"personality\": {\"tone\": \"professional_coach\", \"transparency_level\": \"low\"}, \"temperature\": 0.7, \"content_strategy\": \"curated_only\", \"web_search_enabled\": false}") @map("llm_config")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  interviewSessions InterviewSession[]
  taxonomies        Taxonomy[]

  @@map("coaches")
}

model Taxonomy {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  coachId      String     @map("coach_id") @db.Uuid
  taxonomyType String     @map("taxonomy_type")
  name         String
  slug         String
  parentId     String?    @map("parent_id") @db.Uuid
  metadata     Json       @default("{}")
  createdAt    DateTime   @default(now()) @map("created_at")
  coach        Coach      @relation(fields: [coachId], references: [id], onDelete: Cascade)
  parent       Taxonomy?  @relation("TaxonomyHierarchy", fields: [parentId], references: [id])
  children     Taxonomy[] @relation("TaxonomyHierarchy")

  @@unique([coachId, taxonomyType, slug])
  @@index([coachId])
  @@index([taxonomyType])
  @@index([parentId])
  @@map("taxonomies")
}

model Agent {
  id                  String      @id @default(dbgenerated("gen_random_uuid()")) @map("agent_id") @db.Uuid
  name                String
  prompt              String?
  documentTags        String[]    @map("document_tags")
  status              String      @default("draft")
  createdAt           DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  agentType           agent_type? @map("agent_type")
  liveResearchEnabled Boolean     @default(false) @map("live_research_enabled")

  @@map("agents")
}

model KnowledgeBaseDocument {
  id          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String?
  category    String
  personaType String?              @map("persona_type")
  content     String
  agents      String[]
  status      String               @default("draft")
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  weight      Int                  @default(3)
  chunks      KnowledgeBaseChunk[]

  @@map("knowledge_base_documents")
}

model KnowledgeBaseChunk {
  id         String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId String                 @map("document_id") @db.Uuid
  content    String?
  embedding  Unsupported("vector")?
  chunkIndex Int?                   @map("chunk_index")
  agents     String[]
  category   String?
  createdAt  DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  document   KnowledgeBaseDocument  @relation(fields: [documentId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([agents], map: "idx_knowledge_base_chunks_agents", type: Gin)
  @@index([documentId], map: "idx_knowledge_base_chunks_document_id")
  @@index([embedding], map: "idx_knowledge_base_chunks_embedding")
  @@map("knowledge_base_chunks")
}

model InterviewSession {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  coachId          String    @map("coach_id") @db.Uuid
  userEmail        String?   @map("user_email")
  userName         String?   @map("user_name")
  interviewConfig  Json      @map("interview_config")
  transcript       String?
  scorecardData    Json?     @map("scorecard_data")
  userRating       Int?      @map("user_rating")
  ratingSource     String?   @map("rating_source")
  userFeedback     String?   @map("user_feedback")
  ratingCapturedAt DateTime? @map("rating_captured_at")
  retrievedChunks  Json?     @map("retrieved_chunks")
  aiModelUsed      String?   @map("ai_model_used")
  promptVersion    String?   @map("prompt_version")
  createdAt        DateTime  @default(now()) @map("created_at")
  completedAt      DateTime? @map("completed_at")
  coach            Coach     @relation(fields: [coachId], references: [id], onDelete: Cascade)

  @@index([coachId])
  @@index([userRating])
  @@index([createdAt])
  @@map("interview_sessions")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model system_events {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  route      String
  event_type String
  severity   String
  agent_id   String?   @db.Uuid
  message    String
  metadata   Json?
}

model voice_sessions {
  id         String    @id @db.Uuid
  context    Json
  created_at DateTime? @default(now()) @db.Timestamptz(6)
}

model assessment_comments {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessment_id String      @db.Uuid
  version_id    String?     @db.Uuid
  anchor_text   String
  body          String
  author_id     String      @db.Uuid
  tagged_users  String[]    @default([]) @db.Uuid
  resolved      Boolean     @default(false)
  created_at    DateTime    @default(now()) @db.Timestamptz(6)
  assessments   assessments @relation(fields: [assessment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([assessment_id])
}

model assessment_documents {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessment_id   String            @db.Uuid
  filename        String
  file_size       Int
  storage_path    String
  extracted_text  String?
  uploaded_at     DateTime          @default(now()) @db.Timestamptz(6)
  assessments     assessments       @relation(fields: [assessment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  document_chunks document_chunks[]

  @@index([assessment_id])
}

model assessment_versions {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessment_id  String      @db.Uuid
  version_number String
  content_json   Json
  summary        String?
  created_by     String      @db.Uuid
  created_at     DateTime    @default(now()) @db.Timestamptz(6)
  assessments    assessments @relation(fields: [assessment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([assessment_id])
}

model assessments {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_by           String                 @db.Uuid
  client_name          String
  stakeholders         String[]               @default([])
  project_brief        String?
  draft_content        Json?                  @map("draft_content")
  status               String                 @default("new")
  created_at           DateTime               @default(now()) @db.Timestamptz(6)
  updated_at           DateTime               @default(now()) @db.Timestamptz(6)
  assessment_comments  assessment_comments[]
  assessment_documents assessment_documents[]
  assessment_versions  assessment_versions[]

  @@index([created_by])
  @@index([status])
}

model document_chunks {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessment_id        String                 @db.Uuid
  document_id          String                 @db.Uuid
  chunk_index          Int
  content              String
  embedding            Unsupported("vector")?
  assessment_documents assessment_documents   @relation(fields: [document_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([assessment_id])
  @@index([document_id])
}

enum agent_type {
  Guide
  Analyst
  Builder
  Orchestrator
}
